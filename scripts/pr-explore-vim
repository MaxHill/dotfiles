#!/usr/bin/env bash
set -euo pipefail

# git pr explore-vim [-i|--inline] [range]
# Example:
#   git pr explore-vim
#   git pr explore-vim -i
#   git pr explore-vim origin/master...HEAD

usage() {
  cat <<'EOF'
Usage: git pr explore-vim [-i|--inline] [range]

Options:
  -i, --inline   Use inline preview (default is side-by-side preview)
  -h, --help     Show this help
EOF
}

range=""
delta_layout_opt="--side-by-side"
preview_mode="side-by-side"

while [ "$#" -gt 0 ]; do
  case "$1" in
    -i|--inline)
      delta_layout_opt=""
      preview_mode="inline"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [ -n "$range" ]; then
        echo "Error: only one range argument is supported" >&2
        usage >&2
        exit 1
      fi
      range="$1"
      shift
      ;;
  esac
done

if [ -z "$range" ]; then
  range="origin/main...HEAD"
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: not inside a git repository" >&2
  exit 1
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "Error: fzf is required" >&2
  exit 1
fi

if ! command -v delta >/dev/null 2>&1; then
  echo "Error: delta is required" >&2
  exit 1
fi

while true; do
  files="$(git diff --name-only -M --diff-filter=ACMR "$range")"

  if [ -z "$files" ]; then
    echo "No changed files for range: $range"
    exit 0
  fi

  if ! selected="$(printf '%s\n' "$files" | SHELL=/bin/bash fzf \
    --prompt="pr explore-vim> " \
    --header="enter:open  esc:quit  mode:$preview_mode  ctrl-d/ctrl-u:preview half-page  shift-j/k:preview line" \
    --height=90% \
    --layout=reverse \
    --bind="ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up,J:preview-down,K:preview-up" \
    --preview="git diff -M '$range' -- {} | delta --no-gitconfig --paging=never $delta_layout_opt --width=\${FZF_PREVIEW_COLUMNS:-120}" \
    --preview-window="right,70%,border-left")"; then
    exit 0
  fi

  if [ -z "${selected:-}" ]; then
    exit 0
  fi

  git difftool -y --find-renames --tool=nvimdiff "$range" -- "$selected" || true
done
