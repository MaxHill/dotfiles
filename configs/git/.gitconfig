# This is Git's per-user configuration file.
[user]
	name = Max Hill
	email = max@hills.nu
[github]
	user = maxhill
[core]
	editor = /usr/bin/vim
	excludesfile = ~/.gitignore_global
	pager = delta
[push]
	default = current
	autoSetupRemote = true
[branch]
	autosetuprebase = always
[pull]
	rebase = true
[rerere]
    enabled = true
    autoupdate = true

# Include custom .gitconfig if in work folder
[includeIf "gitdir:~/code/work/"]
    path = ~/code/work/.gitconfig

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true


[credential]
	helper = osxkeychain

# Better built-in diff readability (no external tools)
[color]
	ui = auto
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse

[diff]
	algorithm = histogram
	colorMoved = zebra
	colorMovedWS = allow-indentation-change
	tool = nvimdiff

[difftool]
	prompt = false
[difftool "nvimdiff"]
	cmd = "/opt/homebrew/bin/nvim -d \"$LOCAL\" \"$REMOTE\""

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = OneHalfDark

[merge]
	conflictstyle = zdiff3

[alias]
	lg = log --graph --decorate --oneline
	dv = difftool -y
	dvd = difftool -y -d --find-renames
