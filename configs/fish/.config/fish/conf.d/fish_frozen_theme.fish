# Rosé Pine Dawn theme for Fish shell
# Colors matching the rose-pine dawn colorscheme
# Based on: https://rosepinetheme.com/palette/ingredients

set --global fish_color_autosuggestion 9893a5  # Muted (muted variant)
set --global fish_color_cancel -r
set --global fish_color_command 286983  # Pine (teal/cyan for commands)
set --global fish_color_comment 9893a5  # Muted
set --global fish_color_cwd 575279  # Text (main foreground)
set --global fish_color_cwd_root b4637a  # Love (red accent)
set --global fish_color_end ea9d34  # Gold (yellow accent)
set --global fish_color_error b4637a  # Love (red accent)
set --global fish_color_escape d7827e  # Rose (orange/coral accent)
set --global fish_color_history_current --bold
set --global fish_color_host 575279  # Text
set --global fish_color_host_remote ea9d34  # Gold
set --global fish_color_normal 575279  # Text (main foreground)
set --global fish_color_operator d7827e  # Rose
set --global fish_color_param 575279  # Text
set --global fish_color_quote ea9d34  # Gold
set --global fish_color_redirection 575279 --bold
set --global fish_color_search_match 575279 --background=f2e9e1  # Text on Highlight Low
set --global fish_color_selection 575279 --bold --background=dfdad9  # Text on Surface
set --global fish_color_status b4637a  # Love (red for errors)
set --global fish_color_user 575279  # Text
set --global fish_color_valid_path --underline
set --global fish_pager_color_completion 575279  # Text
set --global fish_pager_color_description 9893a5 -i  # Muted italic
set --global fish_pager_color_prefix 286983 --bold --underline  # Pine
set --global fish_pager_color_progress 575279 --background=f2e9e1  # Highlight Low
set --global fish_pager_color_selected_background -r
